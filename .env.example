# ============================================================
# ANTYGRAVITY — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Discord Webhook ──────────────────────────────────────────
# Go to Server Settings -> Integrations -> Webhooks -> New Webhook
# Copy the Webhook URL and paste it below
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ── YouTube Data API ──────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → YouTube Data API v3
# Create credentials → API Key
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Storage ───────────────────────────────────────────────────
# Max age of clips before auto-cleanup (days)
CLIP_MAX_AGE_DAYS=30
# Max storage to use for clips (GB)
CLIP_MAX_STORAGE_GB=50

# ── Database ─────────────────────────────────────────────────
DB_PATH=./data/db.json

# ── Monitor ──────────────────────────────────────────────────
# How often to check for new videos (minutes)
MONITOR_INTERVAL_MINUTES=5

# ── Server ───────────────────────────────────────────────────
PORT=3000

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
