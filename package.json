{
  "name": "antygravity",
  "version": "1.0.0",
  "description": "YouTube Clip Automation System — Free alternative to StreamSnip",
  "main": "bot/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server/index.js",
    "build": "npm install && npm install --prefix client && npm run build --prefix client",
    "dev:server": "nodemon --ignore data --ignore clips server/index.js",
    "dev:client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "tunnel": "ssh -R 80:127.0.0.1:3000 nokey@localhost.run",
    "go": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run tunnel\""
  },
  "dependencies": {
    "axios": "^1.6.7",
    "bcryptjs": "^3.0.3",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "lowdb": "^1.0.0",
    "mongoose": "^9.5.0",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "AntyGravity",
  "license": "MIT"
}
